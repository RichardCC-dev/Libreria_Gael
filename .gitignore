# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files
#
# IMPORTANTE: Las carpetas backend/, app/, components/, services/, lib/, docs/, contexts/
# NO deben estar aquí. Son esenciales para desplegar la app (Railway + Expo).

# ========== Dependencias ==========
node_modules/

# ========== Expo / React Native ==========
.expo/
dist/
web-build/
expo-env.d.ts

# ========== Native (solo si usas prebuild - EAS Build las genera) ==========
/ios
/android

# ========== Metro ==========
.metro-health-check*

# ========== Debug ==========
npm-debug.*
yarn-debug.*
yarn-error.*

# ========== Sistema / IDE ==========
.DS_Store
*.pem

# ========== Archivos de entorno (secretos - NO subir) ==========
# Usa .env.example como plantilla para documentar variables
.env
.env.local
.env*.local
backend/.env

# ========== TypeScript ==========
*.tsbuildinfo

# ========== Ejemplo/plantilla (no es tu app) ==========
/app-example

# ========== Certificados y claves (seguridad) ==========
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
