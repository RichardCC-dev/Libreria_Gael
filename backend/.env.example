# Variables de entorno para el backend
# Copia a .env y ajusta los valores

# ========== LOCAL (por defecto) ==========
# Usa estas variables para MySQL en tu máquina
DB_HOST=localhost
DB_PORT=3306
DB_NAME=libreria_gael
DB_USER=root
DB_PASSWORD=

# ========== RAILWAY (producción) ==========
# En Railway no definas DB_* - Railway inyecta MYSQL_URL o MYSQLHOST, MYSQLUSER, etc.
# No configures nada aquí; Railway lo hace automáticamente al conectar el servicio MySQL

# JWT
JWT_SECRET=genera_una_clave_segura_con_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=development
