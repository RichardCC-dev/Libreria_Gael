# Variables de entorno para el backend
# Copia a .env y ajusta los valores (en Railway usa Variables del servicio)

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=libreria_gael
DB_USER=root
DB_PASSWORD=

# O usa MYSQL_URL (Railway lo provee)
# MYSQL_URL=mysql://user:pass@host:3306/dbname

# JWT
JWT_SECRET=genera_una_clave_segura_con_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=development
