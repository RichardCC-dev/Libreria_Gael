{
  "name": "libreria-gael-backend",
  "version": "1.0.0",
  "description": "API REST para Librería Gael - Sistema de Gestión de Útiles Escolares",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "node src/scripts/sync-db.js",
    "db:create": "node src/scripts/create-database.js",
    "db:sync": "node src/scripts/sync-db.js",
    "db:seed": "node src/scripts/seed.js",
    "db:setup": "npm run db:create && npm run db:sync && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "sequelize": "^6.37.0",
    "uuid": "^10.0.0"
  }
}
